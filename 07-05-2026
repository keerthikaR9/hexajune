        END LOOP;
        If v_outfile_name2 is not null then
             FND_FILE.PUT_LINE(FND_FILE.LOG,'Output File Name: ' || v_outfile_name2);
             -- Get Log File Name and Path
						SELECT logfile_name, REGEXP_SUBSTR(logfile_name, '[^/\\]+$')
						INTO l_log_full_path2, l_log_file_name2

    DBMS_LOB.open(l_bfile, DBMS_LOB.lob_readonly);
    DBMS_LOB.loadfromfile(l_log_blob, l_bfile, DBMS_LOB.getlength(l_bfile));
    DBMS_LOB.close(l_bfile);

    -- 4. ZIP both files into one archive
    AS_ZIP.add1file(l_zip_blob, v_outfile_name2, l_rtf_blob);
    AS_ZIP.add1file(l_zip_blob, l_log_file_name2, l_log_blob);

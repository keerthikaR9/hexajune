            argument7   => 'Y',
            argument8   => 'Y',
            argument9   => 'F',
            argument10  => 'Y',
            argument11  => 'N',
            argument12  => 'D',
            argument13  => 'Y',
            argument14  => 'Y',
            argument15  => 'N',
            argument16  => NULL,
            argument17  => NULL,
            argument18  => 'N',
            argument19  => NULL,
            argument20  => NULL,

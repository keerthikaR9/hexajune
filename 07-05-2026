						WHERE request_id = l_request_id2;


			  l_zip_name := 'Create Accounting - Receiving_' || l_request_id2 || '.zip';

-- Load output and Log into BLOBs
						DBMS_LOB.createtemporary(l_rtf_blob, TRUE);
						DBMS_LOB.createtemporary(l_log_blob, TRUE);
                        DBMS_LOB.createtemporary(l_zip_blob, TRUE);


			    -- Load RTF

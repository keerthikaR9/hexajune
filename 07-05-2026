	  --ZIP both files into one archive
    AS_ZIP.add1file(l_zip_blob, l_out_file_name, l_out_blob);
    AS_ZIP.add1file(l_zip_blob, l_log_file_name, l_log_blob);
    AS_ZIP.finish_zip(l_zip_blob);

    l_len := DBMS_LOB.getlength(l_zip_blob);

      l_mail_conn := UTL_SMTP.open_connection(l_smtp_host, l_smtp_port, tx_timeout => 300);
      UTL_SMTP.helo(l_mail_conn, l_smtp_host);
      UTL_SMTP.mail(l_mail_conn, l_from_email);

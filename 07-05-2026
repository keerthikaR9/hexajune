PROCEDURE XXOA_SEND_SUCCESS_EMAIL(l_period varchar2)
    IS
      l_subject VARCHAR2(300);
    BEGIN
      l_subject := 'Purchasing Period End Programs completed successfully';


      BEGIN
        SELECT listagg(DESCRIPTION,',') WITHIN GROUP (ORDER BY DESCRIPTION)
        INTO l_to_email
        FROM FND_LOOKUP_VALUES
        WHERE LOOKUP_TYPE ='XXOA_PO_PERIOD_CLOSE_EMAIL' AND LANGUAGE ='US' AND ENABLED_FLAG  ='Y';
        FND_FILE.PUT_LINE(FND_FILE.LOG, 'MAIL_TO List: ' || l_to_email);
      EXCEPTION
      WHEN OTHERS THEN
        FND_FILE.PUT_LINE (FND_FILE.LOG,'Exception fetching l_to_email: ' ||sqlerrm);

      END;



      l_mail_conn := UTL_SMTP.open_connection(l_smtp_host, l_smtp_port, tx_timeout => 300);
      UTL_SMTP.helo(l_mail_conn, l_smtp_host);
      UTL_SMTP.mail(l_mail_conn, l_from_email);

             IF l_to_email IS NOT NULL THEN
        FOR i IN (SELECT regexp_substr(l_to_email, '[^,]+', 1, LEVEL) AS email FROM dual CONNECT BY regexp_substr(l_to_email, '[^,]+', 1, LEVEL) IS NOT NULL)
        LOOP
          UTL_SMTP.rcpt(l_mail_conn, i.email);
        END LOOP;
      END IF;



      UTL_SMTP.open_data(l_mail_conn);
      UTL_SMTP.write_data(l_mail_conn, 'From: ' || l_from_email || UTL_TCP.crlf || 'To: ' || l_to_email || UTL_TCP.crlf || 'Subject: ' || l_subject || UTL_TCP.crlf || 'MIME-Version: 1.0' || UTL_TCP.crlf || 'Content-Type: multipart/mixed; boundary="' || l_boundary || '"' || UTL_TCP.crlf || UTL_TCP.crlf);
   UTL_SMTP.write_data(l_mail_conn, '--' || l_boundary || UTL_TCP.crlf ||
          'Content-Type: text/plain; charset=UTF-8' || UTL_TCP.crlf || UTL_TCP.crlf ||
          'Dear Team' || ',' || UTL_TCP.crlf || UTL_TCP.crlf ||
          'Receipt Accruals - Period-End and Creating Accounting programs completed successfully for '  || l_period ||'.'|| UTL_TCP.crlf || UTL_TCP.crlf ||
          'Kindly close PO period.' || UTL_TCP.crlf || UTL_TCP.crlf ||
          'Best regards,' || UTL_TCP.crlf ||
          'Oman Air IT Team' || UTL_TCP.crlf);
END XXOA_SEND_SUCCESS_EMAIL;
BEGIN

SELECT TO_CHAR(SYSDATE, 'Mon-RR') into l_curr_period FROM dual;


                     FND_FILE.PUT_LINE(FND_FILE.LOG,'Request ID: ' || l_request_id2);
					 l_success_flag := 'E';

              ---Send email with log and output files
                 BEGIN


              FOR i IN 1..10 LOOP
            BEGIN
                SELECT SUBSTR(file_name, INSTR(file_name,'/',-1)+1)

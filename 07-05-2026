SELECT LAST_DAY(ADD_MONTHS(TO_DATE(p_period_name, 'Mon-RR'), -1)) into l_prev_end_date FROM dual;

 BEGIN
        SELECT listagg(DESCRIPTION,',') WITHIN GROUP (ORDER BY DESCRIPTION)
        INTO l_to_email
        FROM FND_LOOKUP_VALUES
        WHERE LOOKUP_TYPE ='XXOA_PO_PERIOD_CLOSE_EMAIL' AND LANGUAGE ='US' AND ENABLED_FLAG  ='Y';
        FND_FILE.PUT_LINE(FND_FILE.LOG, 'MAIL_TO List: ' || l_to_email);
        EXCEPTION
        WHEN OTHERS THEN
        FND_FILE.PUT_LINE (FND_FILE.LOG,'Exception fetching email Ids from the lookup : ' ||sqlerrm);

 END;



if p_period_name = l_prev_period then


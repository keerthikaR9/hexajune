    UTL_SMTP.write_data(l_mail_conn, 'MIME-Version: 1.0' || UTL_TCP.crlf);
    UTL_SMTP.write_data(l_mail_conn, 'Content-Type: multipart/mixed; boundary="' || l_boundary || '"' || UTL_TCP.crlf || UTL_TCP.crlf);

      -- Body
         UTL_SMTP.write_data(l_mail_conn, '--' || l_boundary || UTL_TCP.crlf ||
          'Content-Type: text/plain; charset=UTF-8' || UTL_TCP.crlf || UTL_TCP.crlf ||
          'Dear Team' || ',' || UTL_TCP.crlf || UTL_TCP.crlf ||
          'Receipt Accruals - Period-End program ended in ' || l_status || ' for ' || p_period_name ||'.'|| UTL_TCP.crlf || UTL_TCP.crlf ||
          'Kindly check.' || UTL_TCP.crlf || UTL_TCP.crlf ||
          'Best regards,' || UTL_TCP.crlf ||
          'Oman Air IT Team' || UTL_TCP.crlf);
     --  Zip Attachment Header
    UTL_SMTP.write_data(l_mail_conn, '--' || l_boundary || UTL_TCP.crlf);
    UTL_SMTP.write_data(l_mail_conn, 'Content-Type: application/zip; name="' || l_zip_name || '"' || UTL_TCP.crlf);
    UTL_SMTP.write_data(l_mail_conn, 'Content-Transfer-Encoding: base64' || UTL_TCP.crlf);
    UTL_SMTP.write_data(l_mail_conn, 'Content-Disposition: attachment; filename="' || l_zip_name || '"' || UTL_TCP.crlf || UTL_TCP.crlf);

        -- Base64 Encoding Loop (streaming the zipped BLOB)
		 l_amount := 57;
         l_offset := 1;
    WHILE l_offset <= l_len LOOP
        IF (l_offset + l_amount - 1) > l_len THEN
            l_amount := l_len - l_offset + 1;
        END IF;

        DBMS_LOB.read(l_zip_blob, l_amount, l_offset, l_raw);
        UTL_SMTP.write_data(l_mail_conn, UTL_RAW.cast_to_varchar2(UTL_ENCODE.base64_encode(l_raw))|| UTL_TCP.crlf);
        l_offset := l_offset + l_amount;
    END LOOP;

      -- Finalize and Close
    UTL_SMTP.write_data(l_mail_conn, UTL_TCP.crlf || '--' || l_boundary || '--' || UTL_TCP.crlf);
    UTL_SMTP.close_data(l_mail_conn);
    UTL_SMTP.quit(l_mail_conn);

     IF l_zip_blob IS NOT NULL AND DBMS_LOB.isTemporary(l_zip_blob) = 1 THEN
    DBMS_LOB.freetemporary(l_zip_blob);
END IF;
l_zip_blob := NULL;

IF l_out_blob IS NOT NULL AND DBMS_LOB.isTemporary(l_out_blob) = 1 THEN
    DBMS_LOB.freetemporary(l_out_blob);
END IF;
l_out_blob := NULL;

IF l_log_blob IS NOT NULL AND DBMS_LOB.isTemporary(l_log_blob) = 1 THEN

         );
         COMMIT;

       IF l_request_id2 > 0 THEN
      IF FND_CONCURRENT.WAIT_FOR_REQUEST(l_request_id2, 10, 600, l_phase, l_status, l_dev_phase, l_dev_status, l_message)

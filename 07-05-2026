        IF DBMS_LOB.istemporary(l_log_blob) = 1 THEN DBMS_LOB.freetemporary(l_log_blob); END IF;
		IF DBMS_LOB.istemporary(l_zip_blob) = 1 THEN DBMS_LOB.freetemporary(l_zip_blob); END IF;
END;

END IF;
ELSE
                FND_FILE.PUT_LINE(FND_FILE.LOG,
                'fnd_concurrent.wait_for_request failed for ' || l_request_id);
                l_success_flag := 'E';
END IF;

         ELSE

            FND_FILE.PUT_LINE(FND_FILE.LOG, 'Failed to submit Receipt Accruals - Period-End program');
            l_success_flag := 'E';
        END IF;

  	   -- Submit Step 2: Create Accounting - Receiving
		FND_GLOBAL.APPS_INITIALIZE(0, 51149, 707);
     l_boolean := fnd_request.add_layout('BOM','CSTCRACCRCV','en','US','RTF');
         l_request_id2 := FND_REQUEST.SUBMIT_REQUEST(

      UTL_SMTP.open_data(l_mail_conn);

        -- Mandatory Email Headers
    UTL_SMTP.write_data(l_mail_conn, 'From: ' || l_from_email || UTL_TCP.crlf);
    UTL_SMTP.write_data(l_mail_conn, 'To: ' || l_to_email || UTL_TCP.crlf);

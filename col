SELECT ch.check_id,
       aipa.invoice_id,
       aipa.org_id,
       ch.org_id
FROM   ap_checks_all           ch,
       ap_invoice_payments_all aipa
WHERE  ch.check_id   = aipa.check_id
AND    ch.org_id     = aipa.org_id
AND    DECODE(SUBSTR(TRIM(ch.checkrun_name), 1, 5), 'Quick', ch.check_id, ch.checkrun_id) = &your_check_id;

SELECT ch.check_id,
       ipa.payment_id,
       ipa.payments_complete_flag
FROM   ap_checks_all    ch,
       iby_payments_all ipa
WHERE  ch.payment_id                 = ipa.payment_id(+)
AND    ipa.payments_complete_flag(+) = 'Y'
AND    DECODE(SUBSTR(TRIM(ch.checkrun_name), 1, 5), 'Quick', ch.check_id, ch.checkrun_id) = &your_check_id;

SELECT ch.check_id,
       ch.checkrun_name,
       ch.status_lookup_code,
       ch.attribute_category,
       ch.bank_account_name,
       ch.external_bank_account_id,
       ch.org_id
FROM   ap_checks_all ch
WHERE  DECODE(SUBSTR(TRIM(ch.checkrun_name), 1, 5), 'Quick', ch.check_id, ch.checkrun_id) = &your_check_id;

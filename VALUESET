VALUE SET NAME:XXOA_NBO_MUSCAT_PAYMENT_BATCH

TABLE NAME:(select distinct trim(checkrun_name) checkrun_name, decode(substr(trim(checkrun_name),1,5),'Quick',check_id,checkrun_id) checkrun_id,creation_date,org_id,status_lookup_code,attribute_category,bank_account_name from ap_checks_all) qry

WHERE/ORDER BY:where org_id = :$PROFILES$.org_id
AND status_lookup_code ='NEGOTIABLE'
AND creation_date >= '01-JAN-2024'
AND attribute_category is null
AND bank_account_name IN ( SELECT ATTRIBUTE2 FROM fnd_lookup_values flv WHERE 
    flv.lookup_type = 'XXOA_NBO_EBANKING_BANK_ACCOUNT' 
   AND flv.enabled_flag = 'Y'
    AND UPPER (flv.attribute_category) = UPPER ('EBanking Bank Accounts')
    AND flv.language = 'US')
  order by checkrun_name


VALUE SET NAME:XXOA_AP_MUSCAT_PAYMENT_BATCH

TABLE NAME:(select distinct trim(checkrun_name) checkrun_name, decode(substr(trim(checkrun_name),1,5),'Quick',check_id,checkrun_id) checkrun_id,creation_date,org_id,status_lookup_code,attribute_category,bank_account_name from ap_checks_all) qry

WHERE/ORDER BY:where org_id = :$PROFILES$.org_id
AND status_lookup_code ='NEGOTIABLE'
AND attribute_category is null
AND bank_account_name IN ( select cba.BANK_ACCOUNT_NAME from ce_bank_accounts  cba where cba.bank_id in (
  SELECT cbv.BANK_PARTY_ID FROM CE_BANKS_V cbv WHERE UPPER(cbv.BANK_NAME) LIKE UPPER('%MUSCAT%')))
  order by checkrun_name

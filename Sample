



SELECT DISTINCT
  checkrun_id,
  checkrun_name,
  status_lookup_code,
  bank_account_name,
  check_date
FROM ap_checks_all
WHERE status_lookup_code = 'NEGOTIABLE'
ORDER BY check_date DESC;

SELECT DISTINCT
  ch.checkrun_id,
  ch.checkrun_name,
  ch.bank_account_name,
  br.bank_name,
  ch.status_lookup_code,
  ch.check_date
FROM ap_checks_all    ch,
     ce_bank_accounts ba,
     ce_bank_acct_uses_all cbau,
     ce_bank_branches_v    br
WHERE ch.ce_bank_acct_use_id = cbau.bank_acct_use_id
AND   cbau.bank_account_id   = ba.bank_account_id
AND   ba.bank_branch_id      = br.branch_party_id
AND   ch.status_lookup_code  = 'NEGOTIABLE'
ORDER BY ch.check_date DESC;

SELECT ch.checkrun_id,
       ch.checkrun_name,
       ch.check_id,
       br.bank_name,
       ch.bank_account_name
FROM   ap_checks_all          ch,
       ce_bank_accounts        ba,
       ce_bank_acct_uses_all   cbau,
       ce_bank_branches_v      br
WHERE  ch.ce_bank_acct_use_id  = cbau.bank_acct_use_id
AND    cbau.bank_account_id    = ba.bank_account_id
AND    ba.bank_branch_id       = br.branch_party_id
AND    DECODE(SUBSTR(TRIM(ch.checkrun_name), 1, 5), 'Quick', ch.check_id, ch.checkrun_id) = 34490446
AND    ch.status_lookup_code   = 'NEGOTIABLE'
AND    ch.attribute_category  IS NUL




SELECT ATTRIBUTE1, ATTRIBUTE2
FROM   fnd_lookup_values flv
WHERE  flv.lookup_type           = 'XXOA_SIB_EBANKING_BANK_ACCOUNT'
AND    flv.enabled_flag          = 'Y'
AND    UPPER(flv.attribute_category) = UPPER('Ebanking Bank Accounts')
AND    flv.language              = 'US';






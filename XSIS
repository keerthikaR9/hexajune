  * Program Name : xxsis_attachment_pkg.pkb
  * Language     : PL/SQL
  * Description  : Supporting Documents Extraction
  * History      :
  *
  * Author            Version           Modified
  * --------------   ---------------   ---------------
  *  Annamalai G	  Version: 1.0     09-Jan-2020 (SR 255928)
  *  Annamalai G	  Version: 1.1	   30-Apr-2020 (SR 263976)
  *****************************************************************************************/
  PROCEDURE tranfer_attachments_tran(errbuf              OUT VARCHAR2,
                                     retcode             OUT NUMBER,
                                     p_settlement_period VARCHAR2,
                                     p_from_tran_id      VARCHAR2,
                                     p_to_tran_id        VARCHAR2,
                                     p_conc_tran_id      VARCHAR2,
                                     p_reprocess         VARCHAR2) AS
    CURSOR c_doc(p_inv_num VARCHAR2) IS
      SELECT a.file_name, d.file_data, a.pk1_value, a.pk2_value, a.media_id
        FROM fnd_attached_docs_form_vl a, fnd_lobs d, ra_customer_trx_all t
       WHERE a.user_entity_name = 'RA_CUSTOMER_TRX'
         AND a.function_name = 'ARXTWMAI'
            --         AND a.function_type = 'F'
         AND d.file_id = a.media_id
         AND a.pk1_value = t.customer_trx_id
         AND t.trx_number = p_inv_num
      --       and a.pk2_value = p_inv_num
       ORDER BY a.media_id;

    CURSOR c_header(p_org_id number) IS
	    SELECT ROWID,
             sorgid,
             settlementmonthperiod,
             borgid,
             'M' billing_type,
             invoicenumber,
             transmissionid,
             invoiceheaderid
        FROM xxsis_mbs_out_inv_header_t
      --   where invoicenumber = 'CT20140944'; -- Need to delete
      --Sekar 28-jun-15 begin
       WHERE attribute29 = 'PROCESSED'
         AND ((attribute10 is null and p_reprocess = 'N') OR
             (p_reprocess = 'Y' and attribute10 is not null))
	         AND (settlementmonthperiod, transmissionid) IN
             (SELECT a.settlementmonthperiod, a.transmissionid
                FROM xxsis_mbs_out_inv_header_t a
               WHERE (a.settlementmonthperiod =
                     NVL(p_settlement_period, a.settlementmonthperiod) AND
                     (p_from_tran_id IS NOT NULL OR
                     p_to_tran_id IS NOT NULL OR
                     p_conc_tran_id IS NOT NULL))
                 AND ((p_from_tran_id IS NULL AND p_to_tran_id IS NULL AND
                     p_conc_tran_id IS NULL) OR
                     ((TO_NUMBER(a.transmissionid) >= p_from_tran_id AND
                     TO_NUMBER(a.transmissionid) <= p_to_tran_id) OR
                     a.transmissionid IN
                     (SELECT *
                          FROM TABLE (SELECT CAST(in_list(p_conc_tran_id) AS
                                                  my_table)
                                        FROM DUAL))))
				 AND a.attribute25=p_org_id			-- Added for SR 259267
                 AND EXISTS
               (SELECT 1
                        FROM fnd_attached_docs_form_vl c,
                             fnd_lobs                  d,
                             ra_customer_trx_all       t
                       WHERE c.user_entity_name = 'RA_CUSTOMER_TRX'
                         AND c.function_name = 'ARXTWMAI'
                            --AND c.function_type = 'F'
                         AND d.file_id = c.media_id
                         AND c.pk1_value = t.customer_trx_id
                         AND t.trx_number = a.invoicenumber
						 --AND t.org_id=p_org_id -- Added for SR 259267
                      UNION ALL
                      SELECT COUNT(1)
                        FROM ips_invoice_header             d,
                             ips_invoice_lines              b,
                             ips_import_validation_log_line c
                       WHERE d.invoice_num = a.invoicenumber
                         AND b.invoice_num = d.invoice_num
                         AND b.source_feeder = d.hdr_source_feeder
                            --and b.LINE_INTERFACE_STATUS = 'V'
                         AND b.batch_name = c.batch_code
                            --and c.IMPORT_STATUS = 'V'
                         AND b.org_id = d.hdr_org_id
                         AND b.post_flag = 0));

    cursor c_req(p_folder_name varchar2) is
      select distinct request_id
        from XXSIS_OUT_ATTACHMENTS
       where folder_name = p_folder_name
       order by request_id;

    ar_exp EXCEPTION;
    --    v_server_path varchar2(100) := '/u01/kqerpprod/applprod/prodappl/KQU/11.5.0/XXKQMBS/ATTACHMENT/';
    -- v_server_path   VARCHAR2(100) := fnd_profile.VALUE('XXSISMBSOUTBOUNDATTACHMENTURL');
    v_server_path    VARCHAR2(200);
    v_file_name      VARCHAR2(200);
    v_zip_file_name  VARCHAR2(200);
    v_seq            VARCHAR2(10);
    v_media_id       NUMBER;
    v_foldername     varchar2(100);
    ln_conc_req_id   NUMBER;
    v_request_status BOOLEAN;
    v_phase          VARCHAR2(2000);
    v_wait_status    VARCHAR2(2000);
    v_dev_phase      VARCHAR2(2000);
    v_dev_status     VARCHAR2(2000);
    v_message        VARCHAR2(2000);
    v_url            varchar2(100);
	v_org_id		 NUMBER; --Added for LE SPINOFF
  BEGIN
    /*
     v_file_name := v_server_path||'Sek';
     fnd_file.put_line(fnd_file.LOG,'File Name : '||v_file_name);
    v_cmd := '/bin/mkdir ' || v_file_name;
      fnd_file.put_line(fnd_file.LOG,'Command : '||v_cmd);
       host_command1(p_command => v_cmd);
       */
	   /* Start:: Added for SR 259267 */
	v_org_id :=fnd_profile.value('ORG_ID');
	v_server_path := get_att_path(v_org_id);
	   fnd_file.put_line(fnd_file.LOG,'Org ID : ' || v_org_id);
	   fnd_file.put_line(fnd_file.LOG,'Server Path : ' || v_server_path);

	   /* END:: Added for SR 259267 */
    BEGIN
      SELECT LPAD(NVL(MAX(attribute11), 0) + 1, 5, '0')
        INTO v_seq
        FROM xxsis_mbs_out_inv_header_t
       WHERE attribute10 = 'Processed ' || TRUNC(SYSDATE)
	   AND attribute25=v_org_id -- Added for SR 259267
	   ;
    EXCEPTION
      WHEN OTHERS THEN
        v_seq := '00001';
    END;

    FOR r_header IN c_header(v_org_id) -- Modified for the SR 259267
	LOOP
	--FOR r_header IN c_header LOOP
      v_foldername    := '/MSDF-' || LPAD(r_header.sorgid, 3, '0') || 'F' ||
                         TO_CHAR(SYSDATE, 'YYYYMMDD') || v_seq;
      v_zip_file_name := v_server_path || v_foldername;

      host_command1(p_command => '/bin/mkdir ' || v_zip_file_name);
      v_file_name := v_zip_file_name;

      --Seller Airline Code
      IF r_header.sorgid IS NOT NULL THEN
        v_file_name := v_file_name || '/' || r_header.sorgid;
        host_command1(p_command => '/bin/mkdir ' || v_file_name);
      END IF;

      --Settlement Period
      IF r_header.settlementmonthperiod IS NOT NULL THEN
        v_file_name := v_file_name || '/20' ||
                       SUBSTR(r_header.settlementmonthperiod, 1, 4);
        host_command1(p_command => '/bin/mkdir ' || v_file_name);
        v_file_name := v_file_name || '/' ||
                       SUBSTR(r_header.settlementmonthperiod, 5);
        host_command1(p_command => '/bin/mkdir ' || v_file_name);
      END IF;

      --Receiver Airline Code
      IF r_header.borgid IS NOT NULL THEN
        v_file_name := v_file_name || '/' || r_header.borgid;
        host_command1(p_command => '/bin/mkdir ' || v_file_name);
      END IF;

      --Billing Type
      v_file_name := v_file_name || '/M';
      host_command1(p_command => '/bin/mkdir ' || v_file_name);

      --Invoice Number
      IF r_header.invoicenumber IS NOT NULL THEN
        v_file_name := v_file_name || '/' || r_header.invoicenumber;
        host_command1(p_command => '/bin/mkdir ' || v_file_name);
      END IF;

      --Move the files
      FOR r_doc IN c_doc(r_header.invoicenumber) LOOP
        exportblob(v_file_name || '/' || REPLACE(r_doc.file_name, ' ', ''),
                   r_doc.file_data);
        v_media_id := r_doc.media_id;
      END LOOP;
       fnd_file.put_line(fnd_file.LOG,'Transsys-r Calling Procedure P_INV_OUT');
       fnd_file.put_line(fnd_file.LOG,'Transsys-r_header.invoicenumber--'||r_header.invoicenumber);
      p_inv_out(r_header.invoicenumber,
                v_file_name,
                r_header.invoiceheaderid,
                r_header.transmissionid,
                substr(v_foldername, 2));
      --Calling concurrent program
     fnd_file.put_line(fnd_file.LOG,'came out of P_INV_OUT *** Execution Completed');
     fnd_file.put_line(fnd_file.LOG,'v_seq *** = '||v_seq);
     fnd_file.put_line(fnd_file.LOG,'r_header.invoiceheaderid *** = '||r_header.invoiceheaderid);
     fnd_file.put_line(fnd_file.LOG,'r_header.transmissionid  *** = '||r_header.transmissionid);
      UPDATE xxsis_mbs_out_inv_header_t a
         SET a.attribute10 = 'Processed ' || SYSDATE, a.attribute11 = v_seq
      --   a.attribute9  = v_media_id
       WHERE a.invoiceheaderid = r_header.invoiceheaderid
         AND a.transmissionid = r_header.transmissionid;
         fnd_file.put_line(fnd_file.LOG,'After Update ***');
    END LOOP;

  fnd_file.put_line(fnd_file.LOG,'After COMMIT and End loop ***');
    COMMIT;
    fnd_file.put_line(fnd_file.LOG,'After COMMIT ***');
    --Call SFTP
    fnd_file.put_line(fnd_file.LOG,'Call SFTP -- v_foldername = ***  '||v_foldername);
    if v_foldername is not null then
      -- To Wait for Concurrent Requests ...
      fnd_file.put_line(fnd_file.LOG,'for r_req in c_req ***');
      for r_req in c_req(substr(v_foldername, 2)) loop
      fnd_file.put_line(fnd_file.LOG,'INSIDE LOOP r_req in c_req *** request_id = '||r_req.request_id);
        v_request_status := fnd_concurrent.wait_for_request(request_id => r_req.request_id,
                                                            INTERVAL   => 10,
                                                            max_wait   => 0,
                                                            phase      => v_phase,
                                                            status     => v_wait_status,
                                                            dev_phase  => v_dev_phase,
                                                            dev_status => v_dev_status,
                                                            MESSAGE    => v_message);
        v_dev_phase      := NULL;
        v_dev_status     := NULL;
      end loop;
    /* Start:: Added/Modified for SR 259267 */
	IF v_org_id = 6858
    THEN
        BEGIN
            SELECT directory_path
              INTO v_url
              FROM all_directories
             WHERE directory_name = 'DIR_SIS_SFTP_OGH';

            fnd_file.put_line (fnd_file.LOG, 'v_url = ' || v_url);
            fnd_file.put_line (
                fnd_file.LOG,
                'substr(v_foldername, 2) = ' || SUBSTR (v_foldername, 2));
        EXCEPTION
            WHEN OTHERS
            THEN
                fnd_file.put_line (fnd_file.LOG,
                                   'Exp in getting SFTP path : ' || SQLERRM);
        END;
    ELSIF v_org_id = 84
    THEN
        BEGIN
            SELECT directory_path
              INTO v_url
              FROM all_directories
             WHERE directory_name = 'DIR_SIS_STFP';

            fnd_file.put_line (fnd_file.LOG, 'v_url = ' || v_url);
            fnd_file.put_line (
                fnd_file.LOG,
                'substr(v_foldername, 2) = ' || SUBSTR (v_foldername, 2));
        EXCEPTION
            WHEN OTHERS
            THEN
                fnd_file.put_line (fnd_file.LOG,
                                   'Exp in getting SFTP path : ' || SQLERRM);
        END;
    ELSIF v_org_id = 3878
    THEN
        BEGIN
            SELECT directory_path
              INTO v_url
              FROM all_directories
             WHERE directory_name = 'DIR_SIS_SFTP_CGH';

            fnd_file.put_line (fnd_file.LOG, 'v_url = ' || v_url);
            fnd_file.put_line (
                fnd_file.LOG,
                'substr(v_foldername, 2) = ' || SUBSTR (v_foldername, 2));
        EXCEPTION
            WHEN OTHERS
            THEN
                fnd_file.put_line (fnd_file.LOG,
                                   'Exp in getting SFTP path : ' || SQLERRM);
        END;
    ELSIF v_org_id = 6558 -- Added for SR 263976 (Catering SIS)
    THEN
        BEGIN
            SELECT directory_path
              INTO v_url
              FROM all_directories
             WHERE directory_name = 'DIR_SIS_SFTP_CTS';

            fnd_file.put_line (fnd_file.LOG, 'v_url = ' || v_url);
            fnd_file.put_line (
                fnd_file.LOG,
                'substr(v_foldername, 2) = ' || SUBSTR (v_foldername, 2));
        EXCEPTION
            WHEN OTHERS
            THEN
                fnd_file.put_line (fnd_file.LOG,
                                   'Exp in getting SFTP path : ' || SQLERRM);
        END;
    END IF;
	  /* End:: Added/Modified for SR 259267 */
      BEGIN
      fnd_file.put_line(fnd_file.LOG,'submit_request -- XXSIS_ATTACH_SFTP');
        ln_conc_req_id := fnd_request.submit_request('TRANSSYS',
                                                     'XXSIS_ATTACH_SFTP',
                                                     '',
                                                     '', -- start_time
                                                     FALSE, -- subsequent                                                ,
                                                     v_url, -- url
                                                     substr(v_foldername, 2) -- file name
                                                     );
      EXCEPTION
        WHEN OTHERS THEN
          fnd_file.put_line(fnd_file.LOG,
                            'After Request Submision Error =' || SQLERRM);
      END;

      COMMIT;
    fnd_file.put_line(fnd_file.LOG,'ln_conc_req_id -- '||ln_conc_req_id);
      IF ln_conc_req_id IS NOT NULL THEN
        /*Calling fnd_concurrent.wait_for_request to wait for the program to complete */
        v_request_status := fnd_concurrent.wait_for_request(request_id => ln_conc_req_id,
                                                            INTERVAL   => 10,
                                                            max_wait   => 0,
                                                            phase      => v_phase,
                                                            status     => v_wait_status,
                                                            dev_phase  => v_dev_phase,
                                                            dev_status => v_dev_status,
                                                            MESSAGE    => v_message);
        v_dev_phase      := NULL;
        v_dev_status     := NULL;
      END IF;
    end if;
    --End SFTP
  EXCEPTION
    WHEN ar_exp THEN
      fnd_file.put_line(fnd_file.LOG,
                        'Processed Terminated with errors. ...');
      ROLLBACK;
      retcode := 2;
    WHEN OTHERS THEN
      fnd_file.put_line(fnd_file.LOG,
                        'Processed Terminated with errors. ...');
      errbuf  := 'Extraction Failed. ';
      retcode := 2;
      ROLLBACK;
      fnd_file.put_line(fnd_file.LOG,
                        ' Exception : ' || SQLCODE || ' - ' || SQLERRM);
  END tranfer_attachments_tran;

  PROCEDURE p_inv_out(p_inv_num    VARCHAR2,
                      p_filepath   VARCHAR2,
                      p_invid      number,
                      p_transid    number,
                      v_foldername varchar2) AS
    CURSOR c_acdn IS
      SELECT DISTINCT c.flight_no, c.cat_date, h.user_acdn_no doc_no
        FROM acdn_details             b,
             service_transactions     s,
             catering_schedule_header c,
             acdn_headers             h
       WHERE b.service_trans_no = s.service_trans_no
         AND s.cat_sch_id = c.cat_sch_id
         AND b.acdn_no = h.acdn_no
         AND h.user_acdn_no IN
             (SELECT DISTINCT document_num
                FROM ips_invoice_lines
               WHERE invoice_num = p_inv_num);

    CURSOR c_acsr(p_flight_no VARCHAR2, p_cat_date DATE) IS
      SELECT service_trans_no, multi_ser_no
        FROM service_transactions a, catering_schedule_header b
       WHERE a.cat_sch_id = b.cat_sch_id
         AND b.flight_no = p_flight_no
         AND b.cat_date = p_cat_date
         AND a.service_id = 1;

    CURSOR c_ccd(p_flight_no VARCHAR2, p_cat_date DATE) IS
      SELECT service_trans_no, multi_ser_no
        FROM service_transactions a, catering_schedule_header b
       WHERE a.cat_sch_id = b.cat_sch_id
         AND b.flight_no = p_flight_no
         AND b.cat_date = p_cat_date
         AND a.service_id = 7;

    CURSOR c_misc(p_flight_no VARCHAR2, p_cat_date DATE) IS
      SELECT service_trans_no, multi_ser_no
        FROM service_transactions a, catering_schedule_header b
       WHERE a.cat_sch_id = b.cat_sch_id
         AND b.flight_no = p_flight_no
         AND b.cat_date = p_cat_date
         AND a.service_id = 10;

    CURSOR c_std(p_flight_no VARCHAR2, p_cat_date DATE, p_acdn_no NUMBER) IS
      SELECT DISTINCT u.std_prod_id
        FROM acdn_details             b,
             service_transactions     s,
             catering_schedule_header c,
             acdn_headers             h,
             std_uplift_prod_hdr      u
       WHERE b.service_trans_no = s.service_trans_no
         AND s.cat_sch_id = c.cat_sch_id
         AND b.acdn_no = h.acdn_no
         AND u.service_trans_no = s.service_trans_no
         AND c.flight_no = p_flight_no
         AND c.cat_date = p_cat_date
         AND h.user_acdn_no = p_acdn_no;

    CURSOR c_adhoc(p_flight_no VARCHAR2, p_cat_date DATE) IS
      SELECT DISTINCT associate_service
        FROM adhoc_trans_hdr          a,
             service_transactions     b,
             catering_schedule_header c
       WHERE a.service_trans_no = b.service_trans_no
         AND b.cat_sch_id = c.cat_sch_id
         AND c.flight_no = p_flight_no
         AND c.cat_date = p_cat_date
         AND b.service_id = 4;

    /*  cursor c_cancel(p_FLIGHT_NO varchar2, p_CAT_DATE date) is
    select distinct a.SERVICE_TRANS_NO
      from meal_prod_headers        a,
           service_transactions     b,
           CATERING_SCHEDULE_HEADER c
     where a.SERVICE_TRANS_NO = b.SERVICE_TRANS_NO
       and service_id = 9
       and b.CAT_SCH_ID = c.CAT_SCH_ID
       and c.FLIGHT_NO = p_FLIGHT_NO
       AND c.CAT_DATE = p_CAT_DATE;*/
    ln_cnt           NUMBER;
    ln_org_id        NUMBER;
    ln_org_id_chs    NUMBER;
    ln_conc_req_id   NUMBER;
    v_request_status BOOLEAN;
    v_phase          VARCHAR2(2000);
    v_wait_status    VARCHAR2(2000);
    v_dev_phase      VARCHAR2(2000);
    v_dev_status     VARCHAR2(2000);
    v_message        VARCHAR2(2000);
    v_output_file    VARCHAR2(300);
    v_num            VARCHAR2(50);
  BEGIN
    --  ln_resp_id := fnd_global.resp_id;
    --  ln_appl_id := fnd_global.resp_appl_id;
    fnd_file.put_line(fnd_file.LOG,'Transsys-r Inside Procedure P_INV_OUT');
    --ln_org_id := fnd_global.org_id;

	ln_org_id := fnd_profile.value('ORG_ID'); -- Added for SR 259267

    fnd_file.put_line(fnd_file.LOG,'Transsys-r ln_org_id = '||ln_org_id);
    --   fnd_global.apps_initialize(fnd_global.user_id, ln_resp_id, ln_appl_id);

    -- Invoice Engineering Begin
--    SELECT COUNT(1)
      BEGIN
      SELECT COUNT(1),a.hdr_org_id
      INTO ln_cnt,ln_org_id_chs
--      INTO ln_cnt
      FROM ips_invoice_header             a,
           ips_invoice_lines              b,
           ips_import_validation_log_line c
     WHERE a.hdr_source_feeder = 'LMS'
       AND 1=1--a.hdr_org_id = ln_org_id
       AND a.invoice_num = p_inv_num
       AND b.invoice_num = a.invoice_num
       AND b.source_feeder = a.hdr_source_feeder
       AND b.line_interface_status = 'V'
       AND b.batch_name = c.batch_code
       AND c.import_status = 'V'
       AND b.org_id = a.hdr_org_id
       AND b.post_flag = 0
       group by a.hdr_org_id;
   fnd_file.put_line(fnd_file.LOG,'Transsys-r XXSISIPSILMS Count = '||ln_cnt||' For Invoice Number -- '||p_inv_num);
    IF ln_cnt > 0 THEN
      BEGIN
        ln_conc_req_id := fnd_request.submit_request('TRANSSYS',
                                                     'XXSISIPSILMS',
                                                     '',
                                                     '', -- start_time
                                                     FALSE,
                                                     -- subsequent                                                ,
                                                     ln_org_id_chs,--ln_org_id, -- Org Id
                                                     'LMS', -- Source Feeder
                                                     p_inv_num, -- From Invoice Number
                                                     p_inv_num, -- To Invoce Number
                                                     NULL, -- From Invoice Date
                                                     NULL, -- To Invoice Date
                                                     NULL, -- From Customer
                                                     NULL, -- To Customer
                                                     'N', -- Reprint Flag (Y/N)
                                                     'Y' -- Detailed Report (Y/N)
                                                     );
      EXCEPTION
        WHEN OTHERS THEN
          fnd_file.put_line(fnd_file.LOG,
                            'After Request Submision Error =' || SQLERRM);
      END;
      fnd_file.put_line(fnd_file.LOG,'Transsys-r XXSISIPSILMS Request ID = '||ln_conc_req_id);

      COMMIT;

      insert into XXSIS_OUT_ATTACHMENTS
      values
        (p_invid, --INVOICEHEADERID,
         p_transid, --TRANSMISSIONID,
         p_inv_num, --INVOICENUMBER,
         p_filepath || '/Inv_eng_' || p_inv_num || '.txt', -- FILE_NAME,
         fnd_global.user_id, --CREATED_BY,
         sysdate, --CREATION_DATE,
         fnd_global.user_id, --LAST_UPDATED_BY,
         sysdate, --LAST_UPDATE_DATE,
         null, -- LAST_UPDATE_LOGIN
         v_foldername,
         ln_conc_req_id);
    END IF;
    --END;
  EXCEPTION
    WHEN NO_DATA_FOUND THEN
    fnd_file.put_line(fnd_file.LOG,'Exception Occured in -XXSISIPSILMS-'||SQLERRM);
    WHEN OTHERS THEN
    fnd_file.put_line(fnd_file.LOG,'Exception Occured in -XXSISIPSILMS- '||SQLERRM);
    END;
    -- Invoice Engineering End
  IF ln_org_id=6858 then -- Added for SR 259267
    -- Invoice CIP Begin

--    SELECT COUNT(1)
    BEGIN
    SELECT COUNT(1),a.hdr_org_id
      INTO ln_cnt,ln_org_id_chs
--      INTO ln_cnt
      FROM ips_invoice_header a, ips_invoice_lines b, fnd_lookup_values flv
     WHERE 1=1--a.hdr_org_id = ln_org_id
       AND a.hdr_source_feeder = 'CIP'
       AND flv.lookup_type = 'IPS_SERVICE_TYPES'
       AND flv.LANGUAGE = 'US'
       AND flv.lookup_code = b.line_serv_code
       AND a.invoice_num = p_inv_num
       AND b.source_feeder = a.hdr_source_feeder
       AND b.org_id = a.hdr_org_id
       AND b.invoice_num = a.invoice_num
       AND b.post_flag = 0
       group by a.hdr_org_id;
  fnd_file.put_line(fnd_file.LOG,'Transsys-r XXSISIPSICIP Count = '||ln_cnt||' For Invoice Number -- '||p_inv_num);
    IF ln_cnt > 0 THEN
      BEGIN
        ln_conc_req_id := fnd_request.submit_request('TRANSSYS',
                                                     'XXSISIPSICIP',
                                                     '',
                                                     '', -- start_time
                                                     FALSE,
                                                     -- subsequent                                                ,
                                                     ln_org_id_chs,--ln_org_id, -- Org Id
                                                     'CIP', -- Source Feeder
                                                     p_inv_num, -- From Invoice Number
                                                     p_inv_num, -- To Invoce Number
                                                     NULL, -- From Invoice Date
                                                     NULL, -- To Invoice Date
                                                     NULL, -- From Customer
                                                     NULL, -- To Customer
                                                     'N' -- Reprint Flag (Y/N)
                                                     );
      EXCEPTION

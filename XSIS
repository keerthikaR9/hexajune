/* Start:: Added/Modified for SR 259267 */
  function get_att_path(v_org_id number) return varchar2 is
    v_path varchar2(100);
	v_directory varchar2(200);
  begin
    SELECT A.DIRECTORY_NAME
			INTO v_directory
		FROM all_directories A,
			FND_LOOKUP_VALUES_VL B
		WHERE UPPER(A.DIRECTORY_NAME) = UPPER(B.MEANING)
			AND B.LOOKUP_TYPE             = 'XXSIS_OUTBOUND_ATTACH_MAP'
			--AND B.enabled_flag            = 'Y' -- Commented for fixing the multiple org issue
			AND B.start_date_active      <= SYSDATE
			AND (B.end_date_active       IS NULL
			OR B.end_date_active          > SYSDATE)
			AND UPPER(B.lookup_code)      = UPPER(
			(SELECT name FROM hr_operating_units WHERE organization_id = v_org_id
			));

	select directory_path
      into v_path
      from all_directories
     where directory_name = v_directory;
    return v_path;
  exception
    when others then
      fnd_file.put_line(fnd_file.LOG,
                        'Exp in Getting Attachment path (DIR_TEMP_OUTBOUND_ATTACH) :' ||
                        sqlerrm);
  end;
  /* End:: Added/Modified for SR 259267 */
end XXSIS_ATTACHMENT_PKG;

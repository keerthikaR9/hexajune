<?xml version="1.0" encoding="UTF-8" ?>
<dataTemplate name ="XXSISRECRPT" description="XXSIS ICH Reconciliation Report" version="1.0">
<parameters>
<parameter name="P_FROM_DATE" dataType="DATE" />
<parameter name="P_TO_DATE" dataType="DATE" />
<parameter name="P_TRANS_ID" dataType="VARCHAR2"/>
</parameters>
<dataQuery>
<sqlStatement name="Q_MAIN">
<![CDATA[
SELECT 
    XIHT.INTERNALTRANSMISSIONID,
	XIHT.SETTLEMENTMONTHPERIOD,
	COUNT(XIHT.INVOICENUMBER) INVOICE_COUNT,
    (SELECT COUNT(INVOICENUMBER) FROM XXSIS_INVOICE_HEADER_T WHERE INTERNALTRANSMISSIONID = XIHT.INTERNALTRANSMISSIONID
    AND STATUS = 'MAPPED') UNPROCESSED_INVOICE_COUNT,
    (SELECT COUNT(INVOICENUMBER) FROM XXSIS_INVOICE_HEADER_T WHERE INTERNALTRANSMISSIONID = XIHT.INTERNALTRANSMISSIONID
    AND STATUS NOT IN ('MAPPED','INTERFACED TO AP')) ERROR_INVOICE_COUNT,
	NVL(SUM(ISTOTALAMOUNTCLEARANCECURRENCY),0) TOTAL_AMOUNT,
    (SELECT NVL(SUM(ISTOTALAMOUNTCLEARANCECURRENCY),0) FROM XXSIS_INVOICE_HEADER_T WHERE INTERNALTRANSMISSIONID = XIHT.INTERNALTRANSMISSIONID
    AND STATUS = 'MAPPED') UNPROCESSED_TOTAL_AMOUNT,
    (SELECT NVL(SUM(ISTOTALAMOUNTCLEARANCECURRENCY),0) FROM XXSIS_INVOICE_HEADER_T WHERE INTERNALTRANSMISSIONID = XIHT.INTERNALTRANSMISSIONID
    AND STATUS NOT IN ('MAPPED','INTERFACED TO AP')) ERROR_TOTAL_AMOUNT
FROM APPS.XXSIS_INVOICE_HEADER_T XIHT
WHERE 
    1 = 1
    AND XIHT.INTERNALTRANSMISSIONID = NVL(:P_TRANS_ID,XIHT.INTERNALTRANSMISSIONID)
    AND TRUNC(XIHT.CREATION_DATE) >= NVL(:P_FROM_DATE, TRUNC(XIHT.CREATION_DATE))
    AND TRUNC(XIHT.CREATION_DATE) <= NVL(:P_TO_DATE, TRUNC(XIHT.CREATION_DATE))
GROUP BY 
    XIHT.INTERNALTRANSMISSIONID,XIHT.SETTLEMENTMONTHPERIOD
]]>
</sqlStatement>
<sqlStatement name="Q_UNPROCESSED">
<![CDATA[
SELECT 
    XIHT.INTERNALTRANSMISSIONID,
	XIHT.SETTLEMENTMONTHPERIOD,
	XIHT.INVOICENUMBER,
    TO_CHAR(TO_DATE(XIHT.INVOICEDATE,'YYYY-MM-DD'), 'DD-MON-YYYY') INVOICEDATE,
	XIHT.INVOICETYPE,
	XIHT.CHARGECATEGORY,
	XIHT.SORGDESIGNATOR||XIHT.SORGID IATA_CODE,
    XILT.CHARGECODE,
	XILT.DESCRIPTION,
	SORGNAME1 SUPPLIER_NAME,
	XIHT.CLEARANCECURRENCYCODE,
    ROUND((XILT.CHARGEAMOUNT/XIHT.EXCHANGERATE),2) AMOUNT,
	XIHT.STATUS,
	XIHT.STATUSREASON
FROM APPS.XXSIS_INVOICE_HEADER_T XIHT,
     XXSIS_INVOICE_LINES_T XILT
WHERE 
    XIHT.INVOICEHEADERID = XILT.INVOICEHEADERID
	AND XIHT.INTERNALTRANSMISSIONID = NVL(:P_TRANS_ID,XIHT.INTERNALTRANSMISSIONID)
    AND TRUNC(XIHT.CREATION_DATE) >= NVL(:P_FROM_DATE, TRUNC(XIHT.CREATION_DATE))
    AND TRUNC(XIHT.CREATION_DATE) <= NVL(:P_TO_DATE, TRUNC(XIHT.CREATION_DATE))
    AND XIHT.STATUS = 'MAPPED'
]]>
</sqlStatement>

<sqlStatement name="Q_ERRORED">
<![CDATA[
SELECT XIHT.INTERNALTRANSMISSIONID,
       XIHT.SETTLEMENTMONTHPERIOD,
	   XIHT.INVOICENUMBER,
	   TO_CHAR(TO_DATE(XIHT.INVOICEDATE,'YYYY-MM-DD'), 'DD-MON-YYYY') INVOICEDATE,
	   XIHT.INVOICETYPE,
	   XIHT.CHARGECATEGORY,
	   XIHT.SORGDESIGNATOR||XIHT.SORGID IATA_CODE,
       XILT.CHARGECODE,
	   XILT.DESCRIPTION,
	   SORGNAME1 SUPPLIER_NAME,
	   XIHT.CLEARANCECURRENCYCODE,
       ROUND((XILT.CHARGEAMOUNT/XIHT.EXCHANGERATE),2) AMOUNT,
	   XIHT.STATUS,
	   XIHT.STATUSREASON
FROM   APPS.XXSIS_INVOICE_HEADER_T XIHT,
       XXSIS_INVOICE_LINES_T XILT
WHERE 
       XIHT.INVOICEHEADERID = XILT.INVOICEHEADERID
       AND XIHT.INTERNALTRANSMISSIONID = NVL(:P_TRANS_ID,XIHT.INTERNALTRANSMISSIONID)
	   AND TRUNC(XIHT.CREATION_DATE) >= NVL(:P_FROM_DATE, TRUNC(XIHT.CREATION_DATE))
       AND TRUNC(XIHT.CREATION_DATE) <= NVL(:P_TO_DATE, TRUNC(XIHT.CREATION_DATE))
       AND XIHT.STATUS NOT IN ('MAPPED','INTERFACED TO AP')
]]>
</sqlStatement>
</dataQuery>
